theme = Catppuccin Mocha
# theme = tokyonight

# Font
# font-family = "Symbols Nerd Font Mono"
font-family = "Fira Code Regular"
font-family-bold = "Fira Code Bold"
font-family-italic = "Maple Mono"
font-family-bold-italic = "Maple Mono"
# font-family = Maple Mono
# font-family = Berkeley Mono Trial
font-size = 15
adjust-cell-height = 10%
# font-thicken = true
adjust-underline-position = 4

# Window
window-padding-y = 4
window-padding-x = 4
window-padding-balance = true
# window-decoration = transparent
macos-titlebar-style = hidden

# Other
copy-on-select = clipboard
shell-integration-features = cursor,sudo,no-title

# Keys
# keybind = ctrl+h=goto_split:left
# keybind = ctrl+j=goto_split:bottom
# keybind = ctrl+k=goto_split:top
# keybind = ctrl+l=goto_split:right
# keybind = cmd+shift+t=new_tab
# keybind = cmd+shift+h=previous_tab
# keybind = cmd+shift+l=next_tab
# keybind = cmd+shift+comma=move_tab:-1
# keybind = cmd+shift+period=move_tab:1
# keybind = cmd+shift+c=copy_to_clipboard
# keybind = cmd+shift+v=paste_from_clipboard
# keybind = cmd+shift+enter=new_split:auto
# keybind = cmd+shift+i=inspector:toggle
# keybind = cmd+shift+m=toggle_split_zoom
# keybind = cmd+shift+r=reload_config
# keybind = cmd+shift+s=write_screen_file:open
# keybind = cmd+shift+w=close_surface

# \x01 = ctrl+a
keybind = cmd+digit_1=text:\x01\x31
keybind = cmd+digit_2=text:\x01\x32
keybind = cmd+digit_3=text:\x01\x33
keybind = cmd+digit_4=text:\x01\x34
keybind = cmd+digit_5=text:\x01\x35
keybind = cmd+digit_6=text:\x01\x36
keybind = cmd+digit_7=text:\x01\x37
keybind = cmd+digit_8=text:\x01\x38
keybind = cmd+digit_9=text:\x01\x38

# Select a new tmux session for the attached client interactively
keybind = cmd+k=text:\x01\x73
# Previous tab
keybind = cmd+shift+left_bracket=text:\x01\x70
# Next tab
keybind = cmd+shift+right_bracket=text:\x01\x6e
# Split the current pane into two, left and right
keybind = cmd+shift+n=text:\x01\x22
# Split the current pane into two, top and bottom.
keybind = cmd+n=text:\x01\x25
# Create a new tmux window
keybind = cmd+t=text:\x01\x63
# Break the current tmux pane out of the tmux window
# keybind = cmd+t=text:\x01\x21
# Kill the current tmux pane (and window if last pane)
keybind = cmd+w=text:\x01\x78
# Toggle the zoom state of the current tmux pane
keybind = cmd+z=text:\x01\x7a
